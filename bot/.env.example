# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# TON Center testnet RPC endpoint
TON_TESTNET_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC

# TON Center API key from https://toncenter.com/
TON_API_KEY=your_toncenter_api_key

# 24-word mnemonic for the arbiter wallet (signs confirm/cancel/resolve on-chain)
ARBITER_WALLET_MNEMONIC=word1 word2 word3 ... word24

# URL of the deployed Mini App (for TON Connect payment buttons)
MINI_APP_URL=https://your-mini-app.vercel.app

# Express API server port
PORT=3000
