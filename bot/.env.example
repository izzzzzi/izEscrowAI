# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/izescrow

# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# AI Provider: "openrouter" (default) or "cocoon" (decentralized via TON)
AI_PROVIDER=openrouter

# OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenRouter model (default: openai/gpt-4.1-nano)
OPENROUTER_MODEL=openai/gpt-4.1-nano

# Cocoon (Telegram decentralized AI on TON) — only needed if AI_PROVIDER=cocoon
COCOON_BASE_URL=http://localhost:10000/v1
COCOON_MODEL=Qwen/Qwen3-32B

# TON Center RPC endpoint (mainnet by default, set to testnet URL for development)
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC

# TON Center API key from https://toncenter.com/
TON_API_KEY=your_toncenter_api_key

# 24-word mnemonic for the arbiter wallet (signs confirm/cancel/resolve on-chain)
# Fund with at least 5 TON for gas fees
ARBITER_WALLET_MNEMONIC=word1 word2 word3 ... word24

# URL of the deployed Mini App (for TON Connect payment buttons)
MINI_APP_URL=https://your-mini-app.vercel.app

# Platform wallet address for 1% fee collection
PLATFORM_WALLET_ADDRESS=EQxxxx...your_platform_wallet

# Platform fee in basis points (100 = 1%)
PLATFORM_FEE_BPS=100

# GitHub OAuth App credentials (from github.com/settings/applications/new)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/github/callback

# Comma-separated Telegram IDs of admin users
ADMIN_TELEGRAM_IDS=123456789

# Express API server port
PORT=3000

# NOTE: AI prompts and Trust Score weights are configured via TypeScript files,
# not environment variables. See bot/src/ai/prompts.default.ts and
# bot/src/scoring/weights.default.ts. Copy to prompts.ts / weights.ts to customize.
